                        task.wait(fireRate)
                    end
                end)
            else
                shootSilentAim(input)
            end
        end
        
        if _G.AimlockConfig.enabled and lockedTarget then
            isHoldingFireAimlock = true
            local fireRate = getAutomaticFireRate()
            if fireRate then
                task.spawn(function()
                    while isHoldingFireAimlock and var12_upvw and getAutomaticFireRate() and lockedTarget do
                        if not var12_upvw or not var12_upvw.Parent then
                            isHoldingFireAimlock = false
                            break
                        end
                        if GunFrame.GunNameLabel.Text == "RELOADING" then
                            isHoldingFireAimlock = false
                            break
                        end
                        shootAimlock(input)
                        task.wait(fireRate)
                    end
                end)
            else
                shootAimlock(input)
            end
        end
    end
end)

