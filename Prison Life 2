local function saveDefaultGunColors()
    DefaultGunColors = {}
    local gunNames = {"M9", "Taser", "Remington 870", "AK-47", "M4A1"}
    local partNames = {"Handle", "Muzzle", "Part"}
    
    local function scanTools(parent)
        for _, tool in ipairs(parent:GetChildren()) do
            if table.find(gunNames, tool.Name) then
                for _, partName in ipairs(partNames) do
                    local part = tool:FindFirstChild(partName)
                    if part and part:IsA("Part") then
                        local key = tool.Name .. "_" .. partName
                        DefaultGunColors[key] = part.Color
                    end
                end
            end
        end
    end
    
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        scanTools(backpack)
    end
    
    local character = LocalPlayer.Character
    if character then
        scanTools(character)
    end
end

