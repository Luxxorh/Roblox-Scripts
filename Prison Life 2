local hasPressedReload = false

local function setupAmmoMonitoring()
    for _, connection in pairs(reloadConnections) do
        connection:Disconnect()
    end
    reloadConnections = {}
    
    local character = LocalPlayer.Character
    if not character then return end
    
    for _, gunName in ipairs(monitoredGuns) do
        local gunTool = character:FindFirstChild(gunName)
        if gunTool and gunTool:IsA("Tool") then
            local function checkAndReload()
                if not _G.Settings.EnableAutoReload or hasPressedReload then
                    return
                end
                
                local currentAmmo = gunTool:GetAttribute("CurrentAmmo")
                if not currentAmmo then return end
                
                local shouldReload = false
                
                if gunName == "Remington 870" then
                    shouldReload = currentAmmo <= 1
                elseif gunName == "Taser" then
                    shouldReload = currentAmmo <= 0
                else
                    shouldReload = currentAmmo <= 5
                end
                
                if shouldReload then
                    print("Auto-reload: " .. gunName .. " needs reload (ammo: " .. currentAmmo .. ")")
                    
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.R, false, game)
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                    
                    hasPressedReload = true
                    
                    task.wait(0.05)
                    hasPressedReload = false
                end
            end
            
            if gunTool:GetAttribute("CurrentAmmo") ~= nil then
                local connection = gunTool:GetAttributeChangedSignal("CurrentAmmo"):Connect(checkAndReload)
                table.insert(reloadConnections, connection)
                
                checkAndReload()
            end
        end
    end
end

local function toggleAutoReload(enable)
    if enable then
        hasPressedReload = false
        
        setupAmmoMonitoring()
        
        LocalPlayer.CharacterAdded:Connect(function(character)
            task.wait(1)
            setupAmmoMonitoring()
            hasPressedReload = false
        end)
        
        local character = LocalPlayer.Character
        if character then
            character.ChildAdded:Connect(function(child)
                if table.find(monitoredGuns, child.Name) and child:IsA("Tool") then
                    task.wait(0.5)
                    setupAmmoMonitoring()
                end
            end)
        end
        
    else
        for _, connection in pairs(reloadConnections) do
            connection:Disconnect()
        end
        reloadConnections = {}
        hasPressedReload = false
    end
end

local function isSameTeam(player)
    if player == LocalPlayer then
        return true
    end
    if player.Team and LocalPlayer.Team then
        return player.Team == LocalPlayer.Team
    end
    return false
end

local function getClosestPlayerForSilentAim()
    if not _G.SilentAimConfig.enabled then return nil end
    
    local closestPlayer = nil
    local shortestDistance = _G.SilentAimConfig.fov
    local fovCenter
    
    if _G.SilentAimConfig.followMouse then
        local inputPos = getTouchPosition()
        fovCenter = Vector2.new(inputPos.X, inputPos.Y)
    else
        fovCenter = Vector2.new(screenSize.X / 2, screenSize.Y / 2)
    end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        
        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        
        if _G.SilentAimConfig.teamCheck and isSameTeam(player) then continue end
        
        local targetPart = player.Character:FindFirstChild(_G.SilentAimConfig.targetPart)
        if not targetPart then continue end
        
        if _G.SilentAimConfig.visibleCheck then
            local origin = Camera.CFrame.Position
            local direction = (targetPart.Position - origin).Unit * 1000
            raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
            local result = workspace:Raycast(origin, direction, raycastParams)
            if result and result.Instance and not player.Character:IsAncestorOf(result.Instance) then
                continue
            end
        end
        
        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
        if not onScreen then continue end
        
        local screenPoint = Vector2.new(screenPos.X, screenPos.Y)
        local distance = (screenPoint - fovCenter).Magnitude
        
        if _G.SilentAimConfig.showFov then
            if distance <= _G.SilentAimConfig.fov and distance < shortestDistance then
                shortestDistance = distance
                closestPlayer = player
            end
        else
            if distance < shortestDistance then
                shortestDistance = distance
                closestPlayer = player
            end
        end
    end
    return closestPlayer
end

